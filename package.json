{
  "name": "modcdp",
  "version": "0.0.6",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pirate/modcdp.git"
  },
  "files": [
    "js/src/**/*.ts",
    "js/examples/**/*.ts",
    "js/scripts/**/*.mjs",
    "dist/**/*",
    "dist/extension.zip",
    "extension/src/**/*.ts",
    "extension/src/pages/**/*",
    "extension/manifest.json",
    "python/modcdp/extension.zip",
    "go/modcdp/injector/extension.zip"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./js/src/index.ts",
      "import": "./dist/js/src/index.js",
      "default": "./dist/js/src/index.js"
    },
    "./client": {
      "types": "./js/src/client/ModCDPClient.ts",
      "import": "./dist/js/src/client/ModCDPClient.js",
      "default": "./dist/js/src/client/ModCDPClient.js"
    },
    "./client/ModCDPClient.js": {
      "types": "./js/src/client/ModCDPClient.ts",
      "import": "./dist/js/src/client/ModCDPClient.js"
    },
    "./server/ModCDPServer.js": {
      "types": "./js/src/server/ModCDPServer.ts",
      "import": "./dist/js/src/server/ModCDPServer.js"
    },
    "./launcher/BrowserLauncher.js": {
      "types": "./js/src/launcher/BrowserLauncher.ts",
      "import": "./dist/js/src/launcher/BrowserLauncher.js"
    },
    "./launcher/LocalBrowserLauncher.js": {
      "types": "./js/src/launcher/LocalBrowserLauncher.ts",
      "import": "./dist/js/src/launcher/LocalBrowserLauncher.js"
    },
    "./launcher/RemoteBrowserLauncher.js": {
      "types": "./js/src/launcher/RemoteBrowserLauncher.ts",
      "import": "./dist/js/src/launcher/RemoteBrowserLauncher.js"
    },
    "./launcher/BrowserbaseBrowserLauncher.js": {
      "types": "./js/src/launcher/BrowserbaseBrowserLauncher.ts",
      "import": "./dist/js/src/launcher/BrowserbaseBrowserLauncher.js"
    },
    "./launcher/NoopBrowserLauncher.js": {
      "types": "./js/src/launcher/NoopBrowserLauncher.ts",
      "import": "./dist/js/src/launcher/NoopBrowserLauncher.js"
    },
    "./transport/UpstreamTransport.js": {
      "types": "./js/src/transport/UpstreamTransport.ts",
      "import": "./dist/js/src/transport/UpstreamTransport.js"
    },
    "./transport/WebSocketUpstreamTransport.js": {
      "types": "./js/src/transport/WebSocketUpstreamTransport.ts",
      "import": "./dist/js/src/transport/WebSocketUpstreamTransport.js"
    },
    "./transport/ReverseWebSocketUpstreamTransport.js": {
      "types": "./js/src/transport/ReverseWebSocketUpstreamTransport.ts",
      "import": "./dist/js/src/transport/ReverseWebSocketUpstreamTransport.js"
    },
    "./transport/NativeMessagingUpstreamTransport.js": {
      "types": "./js/src/transport/NativeMessagingUpstreamTransport.ts",
      "import": "./dist/js/src/transport/NativeMessagingUpstreamTransport.js"
    },
    "./transport/PipeUpstreamTransport.js": {
      "types": "./js/src/transport/PipeUpstreamTransport.ts",
      "import": "./dist/js/src/transport/PipeUpstreamTransport.js"
    },
    "./transport/NatsUpstreamTransport.js": {
      "types": "./js/src/transport/NatsUpstreamTransport.ts",
      "import": "./dist/js/src/transport/NatsUpstreamTransport.js"
    },
    "./injector/ExtensionInjector.js": {
      "types": "./js/src/injector/ExtensionInjector.ts",
      "import": "./dist/js/src/injector/ExtensionInjector.js"
    },
    "./injector/DiscoveredExtensionInjector.js": {
      "types": "./js/src/injector/DiscoveredExtensionInjector.ts",
      "import": "./dist/js/src/injector/DiscoveredExtensionInjector.js"
    },
    "./injector/LocalBrowserLaunchExtensionInjector.js": {
      "types": "./js/src/injector/LocalBrowserLaunchExtensionInjector.ts",
      "import": "./dist/js/src/injector/LocalBrowserLaunchExtensionInjector.js"
    },
    "./injector/BBBrowserExtensionInjector.js": {
      "types": "./js/src/injector/BBBrowserExtensionInjector.ts",
      "import": "./dist/js/src/injector/BBBrowserExtensionInjector.js"
    },
    "./injector/ExtensionsLoadUnpackedInjector.js": {
      "types": "./js/src/injector/ExtensionsLoadUnpackedInjector.ts",
      "import": "./dist/js/src/injector/ExtensionsLoadUnpackedInjector.js"
    },
    "./injector/BorrowedExtensionInjector.js": {
      "types": "./js/src/injector/BorrowedExtensionInjector.ts",
      "import": "./dist/js/src/injector/BorrowedExtensionInjector.js"
    },
    "./router/AutoSessionRouter.js": {
      "types": "./js/src/router/AutoSessionRouter.ts",
      "import": "./dist/js/src/router/AutoSessionRouter.js"
    },
    "./proxy/proxy.js": {
      "types": "./js/src/proxy/proxy.ts",
      "import": "./dist/js/src/proxy/proxy.js"
    },
    "./proxy/cli.js": {
      "types": "./js/src/proxy/cli.ts",
      "import": "./dist/js/src/proxy/cli.js"
    },
    "./translate/translate.js": "./dist/js/src/translate/translate.js",
    "./types/*": "./dist/js/src/types/*",
    "./types/generated/*": "./dist/js/src/types/generated/*"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run build:package && pnpm run build:extension-assets && pnpm run build:python-readme",
    "build:clean": "pnpm run clean && pnpm run build",
    "build:package": "tsc -p tsconfig.json && rm -rf dist/js/test",
    "build:extension-assets": "node js/scripts/build-extension-assets.mjs",
    "build:python-readme": "mkdir -p python && if [ README.md -ef python/README.md ]; then :; else cp README.md python/README.md; fi",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm exec prek run --all-files",
    "format": "pnpm exec prek run oxfmt --all-files",
    "format:check": "oxfmt --check .",
    "demo:js": "pnpm run build && node dist/js/examples/demo.js",
    "demo:python": "pnpm run build && cd python && uv run python examples/demo.py",
    "demo:go": "pnpm run build && cd go && go run ./examples/demo",
    "demo:proxy:playwright": "pnpm run build && node dist/js/examples/playwright.js",
    "demo:proxy:puppeteer": "pnpm run build && node dist/js/examples/puppeteer.js",
    "proxy": "pnpm run build && node dist/js/src/proxy/cli.js",
    "test": "pnpm run build && vitest run --fileParallelism=false --maxWorkers=1",
    "test:launchers": "vitest run js/test/test.LocalBrowserLauncher.ts js/test/test.RemoteBrowserLauncher.ts js/test/test.BrowserbaseBrowserLauncher.ts",
    "pack:npm": "pnpm run build && npm pack --ignore-scripts",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eplightning/nats-server": "^2.12.5",
    "@j178/prek": "0.3.10",
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "playwright": "^1.59.1",
    "puppeteer-core": "^24.42.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2"
}
