{
  "manifest_version": 3,
  "name": "ModCDP Bridge",
  "version": "0.1.0",
  "description": "Extension service worker bridge for ModCDP custom commands and events.",
  "key": "",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "modcdp/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "ModCDP"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["activeTab", "tabs", "debugger", "offscreen", "nativeMessaging"],
  "host_permissions": ["<all_urls>", "http://localhost/*", "http://127.0.0.1/*", "ws://localhost/*", "ws://127.0.0.1/*"]
}
